# =============================================================================
# MindForge Demo · Sammelstelle für alle IDs und Tokens aus Phase E
# =============================================================================
# Kopiere diese Datei zu `.env` (steht in .gitignore — wird nie committed)
# und fülle die Werte beim Account-Setup-Sprint aus.
#
# Reihenfolge wie in PHASE-E-PLAN.md §6 Account-Setup-Checkliste.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. HubSpot Free CRM       → hubspot/README.md
# -----------------------------------------------------------------------------
# Anlegen unter app.hubspot.com/signup mit net24.twork@gmail.com
# Region: EU (Germany wählen beim Onboarding)
HUBSPOT_PORTAL_ID=
HUBSPOT_PRIVATE_APP_TOKEN=pat-eu1-

# Custom Properties anlegen via UI oder via API:
#   curl -X POST "https://api.hubapi.com/crm/v3/properties/contacts/batch/create" \
#     -H "Authorization: Bearer $HUBSPOT_PRIVATE_APP_TOKEN" \
#     -H "Content-Type: application/json" \
#     --data @hubspot/properties-export.json


# -----------------------------------------------------------------------------
# 2. Make.com               → make-bridge/README.md
# -----------------------------------------------------------------------------
# Drei Custom-Webhooks anlegen, URLs hier eintragen.
# Connections (HubSpot, Airtable, Slack, HTTP) im Make-UI konfigurieren.
MAKE_WEBHOOK_QUIZ_SUBMIT=https://hook.eu2.make.com/
MAKE_WEBHOOK_HUBSPOT_STATUS=https://hook.eu2.make.com/
MAKE_WEBHOOK_AIRTABLE_CHANGE=https://hook.eu2.make.com/


# -----------------------------------------------------------------------------
# 3. Google Tag Manager     → tracking-full/01-gtm-container.md
# -----------------------------------------------------------------------------
# Anlegen unter tagmanager.google.com → Account "MindForge Demo" → Container
GTM_CONTAINER_ID=GTM-


# -----------------------------------------------------------------------------
# 4. Meta Business Manager  → tracking-full/02-meta-pixel-capi.md
# -----------------------------------------------------------------------------
# Anlegen unter business.facebook.com → Events Manager → Pixel
META_PIXEL_ID=
META_ACCESS_TOKEN=EAA
META_TEST_EVENT_CODE=TEST


# -----------------------------------------------------------------------------
# 5. Google Analytics 4     → tracking-full/03-ga4-dual-stream.md
# -----------------------------------------------------------------------------
# Anlegen unter analytics.google.com → eine Property, ZWEI Web-Streams
GA4_MEASUREMENT_ID_A=G-
GA4_API_SECRET_A=
GA4_MEASUREMENT_ID_B=G-
GA4_API_SECRET_B=


# -----------------------------------------------------------------------------
# 6. TikTok for Business    → tracking-full/04-tiktok-pixel.md
# -----------------------------------------------------------------------------
# Anlegen unter ads.tiktok.com → Tools → Events → Web Events → Pixel
TIKTOK_PIXEL_ID=C
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=


# -----------------------------------------------------------------------------
# Airtable (existiert aus Phase 1)
# -----------------------------------------------------------------------------
AIRTABLE_PERSONAL_ACCESS_TOKEN=pat
AIRTABLE_BASE_ID=app


# -----------------------------------------------------------------------------
# Slack (für Hot-Lead-Notifications, existiert ggf. aus Phase 1)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/
SLACK_HOT_CHANNEL=#sales-hot-leads
SLACK_WARM_CHANNEL=#sales-warm-leads


# -----------------------------------------------------------------------------
# Hinweis: Sobald HUBSPOT_PORTAL_ID und MAKE_WEBHOOK_QUIZ_SUBMIT gesetzt sind,
# kannst du eine `quiz-frontend/config.js` aus `quiz-frontend/config.example.js`
# erstellen mit:
#   window.MF_GTM_ID = "<GTM_CONTAINER_ID>"
#   window.MF_CONFIG = { webhookUrl: "<MAKE_WEBHOOK_QUIZ_SUBMIT>", testMode: true }
# -----------------------------------------------------------------------------
