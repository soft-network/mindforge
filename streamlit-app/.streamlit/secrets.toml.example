# Kopiere diese Datei nach .streamlit/secrets.toml und fülle die Werte aus.
# NIEMALS secrets.toml in Git committen — sie steht in .gitignore.

AIRTABLE_API_TOKEN = "patXXXXXXXXXXXXXX.YOUR_TOKEN_HERE"
AIRTABLE_BASE_ID   = "appXXXXXXXXXXXXXX"
ADMIN_PASSWORD     = "ChooseAStrongPasswordHere"

# -----------------------------------------------------------------------------
# Google OAuth — User-Login-Flow (Phase E2: Setter Daily)
# -----------------------------------------------------------------------------
# Anlegen in der GCP Console:
#   1. APIs & Services → Library → "Google Calendar API" → Enable
#   2. APIs & Services → OAuth consent screen → konfigurieren
#      - User type: External (für Tests reicht das)
#      - Test users: deine Google-Mail eintragen
#      - Scopes: keine zusätzlichen, calendar.events kommt aus dem App-Code
#   3. APIs & Services → Credentials → Create Credentials → OAuth client ID
#      - Application type: Web application
#      - Authorized redirect URIs: http://localhost:8501/oauth/callback
#   4. Client-ID + Client-Secret unten einsetzen.
#
# Beim ersten Streamlit-Aufruf: "Mit Google einloggen" → Consent-Screen →
# zurück zu Streamlit → Tokens in Session.

[google_oauth]
client_id     = "...apps.googleusercontent.com"
client_secret = "..."
redirect_uri  = "http://localhost:8501/oauth/callback"

# -----------------------------------------------------------------------------
# Aircall (optional, Phase E2 — Click-to-Call)
# -----------------------------------------------------------------------------
# Nur ausfüllen wenn ein bezahlter Aircall-Account vorhanden ist und
# integrations/aircall.py auf produktive Implementierung umgebaut wurde.
# Demo-Default: Streamlit-Fallback nutzt tel:-Links.

# [aircall]
# api_id    = "..."
# api_token = "..."
